{
  "name": "@cyanheads/npi-providers-mcp-server",
  "version": "0.1.7",
  "description": "Look up US healthcare providers in the NPPES NPI registry and resolve NUCC specialty codes via MCP. STDIO or Streamable HTTP.",
  "mcpName": "io.github.cyanheads/npi-providers-mcp-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "npi-providers-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run scripts/build.ts",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "bun run scripts/tree.ts",
    "list-skills": "bun run scripts/list-skills.ts",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "lint:packaging": "bun run scripts/lint-packaging.ts",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/npi-providers-mcp-server.mcpb && bun run scripts/clean-mcpb.ts dist/npi-providers-mcp-server.mcpb",
    "changelog:build": "bun run scripts/build-changelog.ts",
    "changelog:check": "bun run scripts/build-changelog.ts --check",
    "release:github": "bun run scripts/release-github.ts",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "bun",
    "stdio",
    "streamable-http",
    "npi",
    "nppes",
    "nucc",
    "healthcare",
    "provider-directory",
    "taxonomy",
    "cms"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/npi-providers-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/npi-providers-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/npi-providers-mcp-server/issues"
  },
  "author": "Casey Hand <casey@caseyjhand.com> (https://caseyjhand.com)",
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.10.14",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "26.1.1",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
